// firestore.rules
// デプロイ: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isAdmin() {
      return request.auth != null
        && (request.auth.uid == 'jJ7BrZ0HhpeC5WYsdZbjRlQBRzK2'
          || request.auth.uid == '49yFkciBJLhFbFq7YJrbg8dI8rf2');
    }

    // ============================================================
    // players/{uid} — プレイヤーデータ
    // ============================================================
    match /players/{uid} {
      // 【修正】ランキング表示のため認証ユーザー全員が読み取り可能に
      allow read: if isAuthed();

      allow create: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.gold is int
        && request.resource.data.gold >= 0
        && request.resource.data.gold <= 10000;  // 初期所持金の上限

      allow update: if isAdmin()
        // 【オークション購入】認証ユーザーが出品者のgoldのみ増額する場合を許可
        || (isAuthed()
            && request.resource.data.gold is int
            && request.resource.data.gold > resource.data.gold
            && request.resource.data.gold <= 100000000
            && request.resource.data.uid == resource.data.uid
            && request.resource.data.get('stats', {}) == resource.data.get('stats', {})
            && request.resource.data.get('inventory', {}) == resource.data.get('inventory', {})
            && request.resource.data.get('banned', false) == resource.data.get('banned', false))
        || (isOwner(uid)
            // 不変フィールドの保護
            && request.resource.data.uid == uid
            // createdAt が既存データにある場合のみ一致を検証
            && (!('createdAt' in resource.data) || request.resource.data.createdAt == resource.data.createdAt)
            // gold は整数・非負・上限あり
            && request.resource.data.gold is int
            && request.resource.data.gold >= 0
            && request.resource.data.gold <= 100000000
            // 【修正】1回のsaveで複数レベル上がる場合があるため+1制限を撤廃
            //   (level は単調増加のみを保証する)
            && (!('stats' in resource.data) || !('stats' in request.resource.data)
                || request.resource.data.stats.get('level', 1) >= resource.data.stats.get('level', 1))
            // banned フラグは本人が書き換えられない
            && request.resource.data.get("banned", false) == resource.data.get("banned", false));

      allow delete: if isAdmin();
    }

    // ============================================================
    // auctions/{listingId} — オークション出品
    // ============================================================
    match /auctions/{listingId} {
      allow read: if isAuthed();
      allow create: if isAuthed()
        && request.resource.data.sellerUid == request.auth.uid
        && request.resource.data.pricePerUnit is int
        && request.resource.data.pricePerUnit >= 1
        && request.resource.data.pricePerUnit <= 10000000
        && request.resource.data.amount is int
        && request.resource.data.amount >= 1
        && request.resource.data.amount <= 9999
        && request.resource.data.expiresAt is int
        && request.resource.data.expiresAt <= request.time.toMillis() + 604800001;
      allow delete: if isAuthed()
        && (resource.data.sellerUid == request.auth.uid || isAdmin());
      allow update: if isAdmin();
    }

    // ============================================================
    // gamble_battles/{battleId} — ギャンブル対戦
    // ============================================================
    match /gamble_battles/{battleId} {
      allow read: if isAuthed();
      allow create: if isAuthed()
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.betAmount is int
        && request.resource.data.betAmount >= 10
        && request.resource.data.betAmount <= 100000
        && request.resource.data.status == 'waiting';
      allow update: if isAuthed()
        && (
          resource.data.hostUid == request.auth.uid
          || ('guestUid' in resource.data && resource.data.guestUid == request.auth.uid)
          || isAdmin()
          || (resource.data.status == 'waiting'
              && resource.data.hostUid != request.auth.uid)
        )
        && request.resource.data.betAmount == resource.data.betAmount
        && request.resource.data.hostUid == resource.data.hostUid;
      allow delete: if isAuthed()
        && (resource.data.hostUid == request.auth.uid || isAdmin());
    }

    // ============================================================
    // board/{messageId} — 掲示板（旧コレクション名、互換性のため残す）
    // ============================================================
    match /board/{messageId} {
      allow read: if isAuthed();
      allow create: if isAuthed()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() >= 1
        && request.resource.data.text.size() <= 200;
      allow delete: if isAuthed()
        && (resource.data.uid == request.auth.uid || isAdmin());
      allow update: if isAdmin();
    }

    // ============================================================
    // board_messages/{messageId} — 掲示板（実際に使用されるコレクション名）
    // ============================================================
    match /board_messages/{messageId} {
      allow read: if isAuthed();
      allow create: if isAuthed()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() >= 1
        && request.resource.data.text.size() <= 200;
      allow delete: if isAuthed()
        && (resource.data.uid == request.auth.uid || isAdmin());
      allow update: if isAdmin();
    }

    // ============================================================
    // online_users/{uid} — オンライン状態
    // ============================================================
    match /online_users/{uid} {
      allow read: if isAuthed();
      allow write: if isOwner(uid);
    }

    // ============================================================
    // admin/{docId} — 管理者設定（ギャンブル倍率・メンテナンス等）
    // ============================================================
    match /admin/{docId} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    // ============================================================
    // sold_notifications/{notifId} — 売却通知
    // ============================================================
    match /sold_notifications/{notifId} {
      allow read: if isAuthed()
        && (resource.data.sellerUid == request.auth.uid
          || resource.data.buyerUid == request.auth.uid
          || isAdmin());
      allow create: if isAuthed()
        && request.resource.data.buyerUid == request.auth.uid
        && request.resource.data.sellerUid is string
        && request.resource.data.totalGold is int
        && request.resource.data.totalGold >= 0;
      // 既読フラグのみ書き換え可（sellerUid 本人）
      allow update: if isAuthed()
        && resource.data.sellerUid == request.auth.uid
        && request.resource.data.read == true
        && request.resource.data.sellerUid == resource.data.sellerUid
        && request.resource.data.totalGold == resource.data.totalGold;
      allow delete: if isAdmin();
    }

    // ============================================================
    // shared/{docId} — 共有設定（お知らせ・ジャックポット・アクティビティ）
    // ============================================================
    match /shared/{docId} {
      allow read: if isAuthed();
      allow write: if isAdmin()
        // ジャックポット積立は認証ユーザー全員が加算のみ可
        || (docId == 'jackpot'
            && isAuthed()
            && request.resource.data.pool is int
            && request.resource.data.pool >= resource.data.get('pool', 0))
        || (docId == 'activity_feed' && isAuthed());
    }

    // ============================================================
    // gamble_feed/{docId} — ギャンブル速報（独立コレクション）
    // ============================================================
    match /gamble_feed/{docId} {
      allow read: if isAuthed();
      allow write: if isAuthed();
    }

    // ============================================================
    // announcements/{docId} — お知らせ履歴
    // ============================================================
    match /announcements/{docId} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    // ============================================================
    // poker_tables/{tableId} — テキサスホールデムテーブル
    // ============================================================
    match /poker_tables/{tableId} {
      allow read: if isAuthed();
      allow create: if isAdmin()
        || (isAuthed()
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.buyIn is int
        && request.resource.data.buyIn >= 100
        && request.resource.data.maxPlayers is int
        && request.resource.data.maxPlayers >= 2
        && request.resource.data.maxPlayers <= 6
        && request.resource.data.status == 'waiting');
      allow update: if isAuthed()
        && request.resource.data.hostUid == resource.data.hostUid
        && request.resource.data.buyIn == resource.data.buyIn;
      allow delete: if isAuthed()
        && (resource.data.hostUid == request.auth.uid || isAdmin());
    }

    // ============================================================
    // activity_feed/{docId} — アクティビティフィード
    // ============================================================
    match /activity_feed/{docId} {
      allow read: if isAuthed();
      // 【修正】uid フィールドの厳密一致チェックを削除（書き込み時にuidが含まれない場合がある）
      allow create: if isAuthed();
      allow delete: if isAdmin();
      allow update: if isAdmin();
    }

    // ============================================================
    // proposals/{proposalId} — 機能提案
    // ============================================================
    match /proposals/{proposalId} {
      allow read: if isAuthed();
      allow create: if isAuthed()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() >= 1
        && request.resource.data.title.size() <= 50
        && request.resource.data.body is string
        && request.resource.data.body.size() >= 1
        && request.resource.data.body.size() <= 500
        && request.resource.data.status == 'pending';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    // gamble_ranking/{uid} — ギャンブルランキング
    // ============================================================
    match /gamble_ranking/{uid} {
      allow read: if isAuthed();
      allow write: if isAuthed();
    }

    // ============================================================
    // slot_jackpot/{tier} — スロットジャックポット
    // ============================================================
    match /slot_jackpot/{tier} {
      allow read: if isAuthed();
      allow write: if isAuthed();
    }

    // ============================================================
    // shared/{docId} の追加ドキュメント許可
    // ============================================================

    // ============================================================
    // gold_transfers/{transferId} — 送金履歴
    // ============================================================
    match /gold_transfers/{transferId} {
      allow read: if isAuthed()
        && (resource.data.senderUid == request.auth.uid
          || resource.data.receiverUid == request.auth.uid
          || isAdmin());
      allow create: if isAuthed()
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.amount is int
        && request.resource.data.amount > 0;
      allow update, delete: if isAdmin();
    }

    // ============================================================
    // transfer_ranking/{uid} — 送金ランキング
    // ============================================================
    match /transfer_ranking/{uid} {
      allow read: if isAuthed();
      allow write: if isAuthed();
    }

    // ============================================================
    // login_bonus/{uid} — ログインボーナス
    // ============================================================
    match /login_bonus/{uid} {
      allow read: if isAuthed() && isOwner(uid);
      allow write: if isAuthed() && isOwner(uid);
    }

    // ============================================================
    // npc_quests/{questId} — NPC依頼
    // ============================================================
    match /npc_quests/{questId} {
      allow read: if isAuthed();
      allow create: if isAuthed();
      allow delete: if isAuthed();
      allow update: if isAdmin();
    }

    // ============================================================
    // quest_ranking/{uid} — 依頼ランキング
    // ============================================================
    match /quest_ranking/{uid} {
      allow read: if isAuthed();
      allow write: if isAuthed();
    }

    // ============================================================
    // stock_market/{docId} — 株式市場価格・履歴
    // ============================================================
    match /stock_market/{docId} {
      allow read: if isAuthed();
      allow write: if isAuthed();
    }

    // ============================================================
    // stock_ranking/{uid} — 株式ランキング
    // ============================================================
    match /stock_ranking/{uid} {
      allow read: if isAuthed();
      allow write: if isAuthed();
    }

    // ============================================================
    // guilds/{guildId} — ギルド
    // ============================================================
    match /guilds/{guildId} {
      allow read: if isAuthed();
      allow create: if isAuthed()
        && request.resource.data.leaderUid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 20;
      allow update: if isAuthed()
        && (resource.data.leaderUid == request.auth.uid
          || resource.data.memberUids.hasAny([request.auth.uid])
          || isAdmin());
      allow delete: if isAuthed()
        && resource.data.leaderUid == request.auth.uid;
      match /members/{uid} {
        allow read: if isAuthed();
        allow write: if isAuthed();
      }
      match /chat/{msgId} {
        allow read: if isAuthed();
        allow create: if isAuthed();
        allow delete: if isAdmin();
      }
    }

    // ============================================================
    // friends/{uid}/list/{friendUid} — フレンドリスト
    // ============================================================
    match /friends/{uid}/list/{friendUid} {
      allow read: if isAuthed() && isOwner(uid);
      allow write: if isAuthed();
    }

    // ============================================================
    // friend_requests/{reqId} — フレンド申請
    // ============================================================
    match /friend_requests/{reqId} {
      allow read: if isAuthed()
        && (resource.data.fromUid == request.auth.uid
          || resource.data.toUid == request.auth.uid);
      allow create: if isAuthed()
        && request.resource.data.fromUid == request.auth.uid;
      allow delete: if isAuthed()
        && (resource.data.fromUid == request.auth.uid
          || resource.data.toUid == request.auth.uid);
      allow update: if isAdmin();
    }

    // ============================================================
    // direct_messages/{msgId} — DM
    // ============================================================
    match /direct_messages/{msgId} {
      allow read: if isAuthed()
        && (resource.data.fromUid == request.auth.uid
          || resource.data.toUid == request.auth.uid);
      allow create: if isAuthed()
        && request.resource.data.fromUid == request.auth.uid;
      allow update: if isAuthed()
        && resource.data.toUid == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ============================================================
    // friend_count_ranking/{uid} — フレンド数ランキング
    // ============================================================
    match /friend_count_ranking/{uid} {
      allow read: if isAuthed();
      allow write: if isAuthed() && isOwner(uid);
    }

    // ============================================================
    // それ以外は全拒否
    // ============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
