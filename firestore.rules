// firestore.rules
// デプロイ: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // 管理者判定: Firestoreの admins/{uid} ドキュメントの存在で判定
    // （Sparkプランでは Cloud Functions が使えないためトークンクレーム方式は不使用）
    function isAdmin() {
      return isAuthed()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ============================================================
    // admins/{uid} — 管理者リスト
    // 最初の管理者は Firebase Console から手動で作成すること
    // ============================================================
    match /admins/{uid} {
      // 自分が管理者かどうかは自分だけ読める（isAdmin()の判定に必要）
      allow read: if isAuthed() && isOwner(uid);
      // 管理者の追加・削除は既存管理者のみ可能
      allow write: if isAdmin();
    }

    // ============================================================
    // players/{uid} — プレイヤーデータ
    // ============================================================
    match /players/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      allow create: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.gold is int
        && request.resource.data.gold >= 0
        && request.resource.data.gold <= 999999999;

      // 管理者は制限なし、本人は gold 増加上限・不変フィールドを保護
      allow update: if isAdmin()
        || (isOwner(uid)
          && request.resource.data.uid == uid
          && request.resource.data.gold is int
          && request.resource.data.gold >= 0
          && request.resource.data.gold <= 100000000
          && (request.resource.data.gold - resource.data.gold) <= 50000
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.createdAt == resource.data.createdAt);

      allow delete: if isAdmin();
    }

    // ============================================================
    // auctions/{listingId} — オークション出品
    // ============================================================
    match /auctions/{listingId} {
      allow read: if isAuthed();
      allow create: if isAuthed()
        && request.resource.data.sellerUid == request.auth.uid
        && request.resource.data.pricePerUnit is int
        && request.resource.data.pricePerUnit >= 1
        && request.resource.data.pricePerUnit <= 10000000
        && request.resource.data.amount is int
        && request.resource.data.amount >= 1
        && request.resource.data.amount <= 9999
        && request.resource.data.expiresAt is int
        && request.resource.data.expiresAt <= request.time.toMillis() + 604800001;
      allow delete: if isAuthed()
        && (resource.data.sellerUid == request.auth.uid || isAdmin());
      allow update: if isAdmin();
    }

    // ============================================================
    // gamble_battles/{battleId} — ギャンブル対戦
    // ============================================================
    match /gamble_battles/{battleId} {
      allow read: if isAuthed();
      allow create: if isAuthed()
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.betAmount is int
        && request.resource.data.betAmount >= 10
        && request.resource.data.betAmount <= 100000;
      allow update: if isAuthed()
        && (resource.data.hostUid == request.auth.uid
          || resource.data.guestUid == request.auth.uid
          || isAdmin());
      allow delete: if isAuthed()
        && (resource.data.hostUid == request.auth.uid || isAdmin());
    }

    // ============================================================
    // board/{messageId} — 掲示板
    // ============================================================
    match /board/{messageId} {
      allow read: if isAuthed();
      allow create: if isAuthed()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() >= 1
        && request.resource.data.text.size() <= 200;
      allow delete: if isAuthed()
        && (resource.data.uid == request.auth.uid || isAdmin());
      allow update: if isAdmin();
    }

    // ============================================================
    // online_users/{uid} — オンライン状態
    // ============================================================
    match /online_users/{uid} {
      allow read: if isAuthed();
      allow write: if isOwner(uid);
    }

    // ============================================================
    // admin/{docId} — 管理者設定（ギャンブル倍率など）
    // ============================================================
    match /admin/{docId} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    // ============================================================
    // sold_notifications/{notifId} — 売却通知
    // ============================================================
    match /sold_notifications/{notifId} {
      allow read: if isAuthed()
        && (resource.data.sellerUid == request.auth.uid
          || resource.data.buyerUid == request.auth.uid
          || isAdmin());
      allow create: if isAuthed();
      allow update: if isAuthed()
        && (resource.data.sellerUid == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ============================================================
    // shared/{docId} — 共有設定（お知らせ等）
    // ============================================================
    match /shared/{docId} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
